{
  "name": "@aegis-ai/aegis-guard",
  "version": "0.1.0",
  "description": "AEGIS PALADIN defense plugin for OpenClaw AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aegis",
    "openclaw",
    "ai-security",
    "agent-defense",
    "prompt-injection",
    "llm-safety"
  ],
  "author": "AEGIS Team <aegis@yatavent.com>",
  "license": "MIT",
  "homepage": "https://aiaegis.io/integrations/openclaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-aegis-yatav/aegis-sdk.git",
    "directory": "integrations/openclaw"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aegis-ai/sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  }
}
